# ─────────────────────────────────────────────────────────────────────────────
# AI Sales Co-Pilot — Environment Variables
# Copy this file to .env and fill in your real values:
#   cp .env.example .env
# ─────────────────────────────────────────────────────────────────────────────

# ── Groq LLM (FREE — required for AI responses) ───────────────────────────────
# Get key: https://console.groq.com → API Keys → Create API Key
# Free tier: 30 req/min, 6000 tokens/min, 500K tokens/day
GROQ_API_KEY='your_groq_api_key_here'
# Model options (pick one — default is llama-3.3-70b-versatile):
#   llama-3.3-70b-versatile   ← best quality, recommended
#   llama3-8b-8192            ← fastest
#   mixtral-8x7b-32768        ← good for long outputs
#   gemma2-9b-it              ← lightweight
GROQ_MODEL='your_groq_model_choice_here'

# ── Pinecone (optional — persistent vector store across restarts) ──────────────
# Get key: https://app.pinecone.io → API Keys → Create API Key
# Free tier: 1 index, 100K vectors
# Embeddings are generated locally using sentence-transformers (no extra API needed)
# After adding key, run: cd backend && python setup_pinecone.py
PINECONE_API_KEY='your_pinecone_api_key_here'
PINECONE_INDEX=sales-copilot

# ── Gmail API (optional — send emails directly from the dashboard) ─────────────
# Step 1: https://console.cloud.google.com → New Project → Enable Gmail API
# Step 2: APIs & Services → Credentials → Create OAuth Client ID (Desktop App)
# Step 3: Download JSON → save as backend/credentials.json
# Step 4: Run once to authorize:
#         python -c "from app.services.gmail_service import authorize_gmail; authorize_gmail()"
# Human-in-the-loop: user always reviews + confirms before email is sent
GMAIL_SENDER=yourname@gmail.com

# ── App Config ────────────────────────────────────────────────────────────────
BACKEND_PORT=8002
FRONTEND_URL=http://localhost:3000
